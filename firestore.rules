rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This is a single-user personal app with anonymous auth (see js/push.js).
    // Any signed-in client (anonymous or not) can read/write its own reminders
    // and register a device token. If you ever add multiple accounts, scope
    // these further by request.auth.uid.
    match /deviceTokens/{tokenId} {
      allow read, write: if request.auth != null;
    }
    match /reminders/{reminderId} {
      allow read, write: if request.auth != null;
    }
  }
}
